<?xml version="1.0" encoding="utf-8"?>
<input-method xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:settingsActivity="org.fcitx.fcitx5.android.ui.main.MainActivity"
    android:supportsInlineSuggestions="true"
    android:supportsSwitchingToNextInputMethod="true"
    tools:targetApi="30">
    <subtype
        android:icon="@mipmap/ic_launcher"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="true"
        android:label="@string/app_name"
        android:overridesImplicitlyEnabledSubtype="true"
        android:imeSubtypeExtraValue="AsciiCapable,EmojiCapable,TrySuppressingImeSwitcher" />

    <subtype
        android:icon="@mipmap/ic_launcher"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="true"
        android:label="@string/app_name"
        android:imeSubtypeLocale="zh"
        android:languageTag="zh-Hans"
    />

    <subtype
        android:icon="@mipmap/ic_launcher"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="true"
        android:label="@string/app_name"
        android:imeSubtypeLocale="zh-rCN"
        android:languageTag="zh-CN"
    />

    <subtype
        android:icon="@mipmap/ic_launcher"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="true"
        android:label="@string/app_name"
        android:imeSubtypeLocale="zh-Hans-CN"
        android:languageTag="zh-CN"
    />

</input-method>
